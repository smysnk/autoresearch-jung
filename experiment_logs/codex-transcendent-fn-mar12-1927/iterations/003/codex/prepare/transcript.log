from math import ceil
VOCAB=8192
HEAD_DIM=128

def config(depth, aspect, use_ve, ve_layers=None):
    n_embd = ceil(depth*aspect/HEAD_DIM)*HEAD_DIM
    heads = n_embd//HEAD_DIM
    # approximate using observed 8x512 noVE transformer matrix count / layer
    # but do exact formulas from code shapes
    d=n_embd
    h=heads
    hd=HEAD_DIM
    attn = d*h*hd + d*h*hd + d*h*hd + d*d  # q,k,v,proj no bias
    mlp = d*(4*d) + (4*d)*d
    per_layer = attn + mlp
    transformer = per_layer * depth
    wte = VOCAB*d
    lm_head = VOCAB*d
    scalars = 2*depth
    if ve_layers is None:
        ve_layers = (depth+1)//2 if use_ve else 0
    value = ve_layers * VOCAB * d
    total = transformer + wte + lm_head + scalars + value
    return dict(depth=depth, aspect=aspect, n_embd=d, heads=heads, ve_layers=ve_layers, total=total/1e6, transformer=transformer/1e6, value=value/1e6)

cands = [
    ('anchor',8,64,True,4),
    ('noVE',8,64,False,0),
    ('deep_noVE',10,48,False,0),
    ('thin_VE',8,48,True,4),
    ('deep_thin_VE',10,48,True,5),
    ('sparse_VE_2',8,64,True,2),
    ('sparse_VE_3',8,64,True,3),
]
for name,depth,aspect,use_ve,ve_layers in cands:
    cfg=config(depth,aspect,use_ve,ve_layers)
    print(name, cfg)
