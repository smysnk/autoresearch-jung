# Repo source plus shared SSH private key for local git pushes and SSH transport
AUTORESEARCH_REPO=smysnk/autoresearch
# Enable local Codex CLI orchestration inside the runners
AUTORESEARCH_USE_CODEX=1
AUTORESEARCH_CODEX_EXECUTABLE=codex
AUTORESEARCH_CODEX_MODEL=
AUTORESEARCH_CODEX_PROFILE=
AUTORESEARCH_CODEX_BYPASS_SANDBOX=1
# Optional SSH target for scripts/remote_runner.py
AUTORESEARCH_REMOTE_HOST=
AUTORESEARCH_REMOTE_DIR=
# Runpod credentials and default profile selection from profiles.json
RUNPOD_API_KEY=
RUNPOD_PROFILE=1
RUNPOD_EXPERIMENT_COUNT=1
RUNPOD_SSH_PRIVATE_KEY=~/.ssh/id_ed25519
